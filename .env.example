# Tailscale auth key from the Tailscale admin console.
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Name this container will use inside your Tailnet.
TS_HOSTNAME=openai-terminal-mcp-gateway

# Optional extra flags for `tailscale up`, e.g. --advertise-tags=tag:mcp-gateway
TS_EXTRA_ARGS=

# OpenAI Secure MCP Tunnel values.
CONTROL_PLANE_TUNNEL_ID=tunnel_REPLACE_ME
CONTROL_PLANE_API_KEY=sk-REPLACE_ME

# Terminal MCP settings.
MCP_SHELL=/bin/bash
MCP_COMMAND_TIMEOUT=300

# tunnel-client health endpoint exposed by docker-compose on host port 8080.
TUNNEL_HEALTH_ADDR=0.0.0.0:8080
