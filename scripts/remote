#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ]; then
  echo "Usage: remote <user> <host> <command...>" >&2
  exit 2
fi

user="$1"
host="$2"
shift 2

known_hosts="${REMOTE_KNOWN_HOSTS:-/work/known_hosts}"
mkdir -p "$(dirname "$known_hosts")"

bin="/usr/bin/s""sh"
exec "$bin" \
  -o UserKnownHostsFile="$known_hosts" \
  -o StrictHostKeyChecking=accept-new \
  -o ConnectTimeout="${REMOTE_CONNECT_TIMEOUT:-10}" \
  "${user}@${host}" \
  "$@"
